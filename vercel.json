{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/db run push-force ; pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/idea-journal run build",
  "outputDirectory": "artifacts/idea-journal/dist/public",
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "functions": {
    "api/[...path].cjs": {
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].cjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
