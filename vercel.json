{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/idea-journal run build",
  "outputDirectory": "artifacts/idea-journal/dist/public",
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "routes": [
    { "src": "/api/dashboard", "dest": "/api/dashboard.js" },
    { "src": "/api/activity", "dest": "/api/activity.js" },
    { "src": "/api/ideas/([^/]+)/progress", "dest": "/api/ideas/[id]/progress.js" },
    { "src": "/api/ideas/([^/]+)", "dest": "/api/ideas/[id].js" },
    { "src": "/api/ideas", "dest": "/api/ideas.js" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/favicon.svg", "dest": "/favicon.svg" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
