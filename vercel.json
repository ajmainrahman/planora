{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/idea-journal run build",
  "outputDirectory": "artifacts/idea-journal/dist/public",
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "routes": [
    { "src": "/api/auth/register", "dest": "/api/auth/register.js" },
    { "src": "/api/auth/login",    "dest": "/api/auth/login.js" },
    { "src": "/api/auth/logout",   "dest": "/api/auth/logout.js" },
    { "src": "/api/auth/me",       "dest": "/api/auth/me.js" },
    { "src": "/api/(.*)",          "dest": "/api/[...path].cjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)",              "dest": "/index.html" }
  ]
}
